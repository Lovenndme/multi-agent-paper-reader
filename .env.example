# Zhipu GLM API Configuration
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
MODEL_NAME=glm-5.2
LLM_TEMPERATURE=1.0
LLM_TIMEOUT_SECONDS=240

# Optional vision model for rendered PDF figures/charts.
# For Z.AI / BigModel, glm-5v-turbo is the recommended high-capability option.
ENABLE_VISION_SUMMARY=true
VISION_MODEL_NAME=glm-5v-turbo
VISION_TEMPERATURE=0.2
VISION_MAX_TOKENS=1200
VISION_TIMEOUT_SECONDS=180
VISION_MAX_FIGURES=0
VISION_MAX_WORKERS=0
VISION_RATE_LIMIT_RETRIES=3
VISION_RETRY_WORKERS=1
VISION_RETRY_DELAY_SECONDS=2.0
VISION_RENDER_DPI=144

# Alternative OpenAI-compatible provider (legacy variable names are supported)
# OPENAI_API_KEY=your_dashscope_key
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MODEL_NAME=qwen-plus
