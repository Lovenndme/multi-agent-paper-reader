# Application and active model routing
TEXT_PROVIDER=zhipu
MODEL_NAME=glm-5.2
# Optional catalog mode ID. Examples: GLM-5.2 standard/deep/fast,
# Qwen thinking/fast, and Kimi or DeepSeek enabled/disabled.
MODEL_MODE=
ENABLE_VISION_SUMMARY=true
VISION_PROVIDER=zhipu
VISION_MODEL_NAME=glm-5v-turbo

# Vision routing follows TEXT_PROVIDER automatically. The two VISION_* values
# are retained for compatibility and are normalized by Settings when saved.

# Optional local Codex subscription route. Connect with browser/device login in
# Settings, then choose a live Sol/Terra/Luna model and one of its six displayed
# reasoning positions. No API key, OAuth token, or Codex auth data belongs here.
# The pinned Python SDK installs runtime 0.144.4; override the binary only for
# local development or troubleshooting.
CODEX_SDK_BIN=
CODEX_SDK_TIMEOUT_SECONDS=240

# Provider credentials and protocol-specific endpoints
# Configure only the providers you plan to use. Never commit real keys.
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ARK_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
MOONSHOT_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

# Optional relay/gateway. CUSTOM_API_PROTOCOL must be exactly "openai" or
# "anthropic". Set CUSTOM_VISION_MODEL empty to explicitly disable image input.
CUSTOM_PROVIDER_NAME=自定义中转站
CUSTOM_API_PROTOCOL=openai
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_TEXT_MODEL=
CUSTOM_VISION_MODEL=

# The optional server-side model health endpoint caches catalog checks.
MODEL_CATALOG_HEALTH_TTL_SECONDS=900
MODEL_CATALOG_HEALTH_TIMEOUT_SECONDS=15

# Generation behavior
LLM_TEMPERATURE=1.0
CHAT_TEMPERATURE=0.25
LLM_TIMEOUT_SECONDS=240
# Dynamic input budget shared by paper evidence, recent turns, and long-term memory.
CHAT_INPUT_TOKEN_BUDGET=48000
# Dynamic input budget for balanced evidence retrieval across comparison papers.
COMPARISON_CHAT_INPUT_TOKEN_BUDGET=56000
SEMANTIC_SCHOLAR_API_KEY=

# Persistent local paper history (analysis JSON, full evidence, and original PDFs).
PAPER_READER_DATA_DIR=.paper-reader
# PAPER_HISTORY_DB=.paper-reader/history.sqlite3

# Optional vision processing for rendered PDF figures/charts.
VISION_TEMPERATURE=0.2
VISION_MAX_TOKENS=1200
VISION_TIMEOUT_SECONDS=180
VISION_MAX_FIGURES=0
VISION_MAX_WORKERS=0
VISION_RATE_LIMIT_RETRIES=3
VISION_RETRY_WORKERS=1
VISION_RETRY_DELAY_SECONDS=2.0
VISION_RENDER_DPI=144

# The Settings UI can also save provider-specific keys and routing here.
# Legacy OPENAI_API_KEY + OPENAI_BASE_URL configurations for compatible
# providers are still detected automatically.
